<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent loop if it's already rewritten to dist/apps/web
    RewriteCond %{REQUEST_URI} !^/dist/apps/web/

    # Skip files that actually exist in the root
    RewriteCond %{REQUEST_FILENAME} !-f

    # Rewrite all requests to the built React app folder
    RewriteRule ^(.*)$ dist/apps/web/$1 [L]
</IfModule>
