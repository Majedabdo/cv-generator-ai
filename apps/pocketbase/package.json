{
	"name": "pocketbase-app",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "pocketbase.exe serve --http=0.0.0.0:8090 --hooksWatch=false",
		"start": "pocketbase.exe serve --http=0.0.0.0:8090 --dir=/data --migrationsDir=./pb_migrations --hooksDir=./pb_hooks --hooksWatch=false",
		"migrations:up": "pocketbase.exe horizons migrations:up --dir=./pb_data --migrationsDir=./pb_migrations --hooksDir=./pb_hooks --hooksWatch=false",
		"migrations:revert": "pocketbase.exe horizons migrations:revert --dir=./pb_data --migrationsDir=./pb_migrations --hooksDir=./pb_hooks --hooksWatch=false",
		"migrations:snapshot": "powershell -Command \"New-Item -ItemType Directory -Force -Path ./pb_snapshots; echo 'y' | pocketbase.exe migrate collections --dir=./pb_data --migrationsDir=./pb_snapshots\"",
		"update": "pocketbase.exe update --backup=0"
	}
}
